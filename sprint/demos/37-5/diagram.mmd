sequenceDiagram
    participant Narrator as Narrator Agent<br/>(Claude CLI)
    participant GameEngine as sidequest-game<br/>(Rust)
    participant DaemonClient as sidequest-daemon-client<br/>(Rust)
    participant Daemon as sidequest-daemon<br/>(Python)
    participant EmbedWorker as EmbedWorker<br/>(sentence-transformers)

    Narrator->>GameEngine: needs lore context for scene
    GameEngine->>DaemonClient: embed("dark cavern with runes")
    DaemonClient->>Daemon: JSON-RPC /embed {text: "..."}

    alt BEFORE FIX — embed worker crashes with empty message
        Daemon->>Daemon: RuntimeError("") raised
        Daemon->>Daemon: str(e) → ""
        Daemon-->>DaemonClient: {error: {code: -32000, message: ""}}
        DaemonClient-->>GameEngine: EmbedError("Unknown error")
        GameEngine-->>Narrator: no context — narrate blind
        Note over Narrator: Session-wide RAG degradation
    end

    alt AFTER FIX — embed worker crashes with diagnostic message
        Daemon->>Daemon: RuntimeError("") raised
        Daemon->>Daemon: str(e) or "RuntimeError (no message)"
        Daemon-->>DaemonClient: {error: {code: -32000, message: "RuntimeError (no message)"}}
        DaemonClient-->>GameEngine: EmbedError("RuntimeError (no message)")
        Note over GameEngine: OTEL span carries real error text
    end

    alt HAPPY PATH — embed succeeds
        Daemon->>EmbedWorker: encode("dark cavern with runes")
        EmbedWorker-->>Daemon: float32[384]
        Daemon-->>DaemonClient: {result: {embedding: [0.042, -0.117, ...]}}
        DaemonClient-->>GameEngine: EmbedResult { embedding: Vec<f32> }
        GameEngine->>GameEngine: LoreStore.similarity_search()
        GameEngine-->>Narrator: top-k relevant lore entries
        Note over Narrator: Contextual narration with memory
    end