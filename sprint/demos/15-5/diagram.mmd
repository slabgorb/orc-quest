sequenceDiagram
    participant Game as Game Engine<br/>(sidequest-server)
    participant Client as Daemon Client<br/>(sidequest-daemon-client)
    participant Types as types.rs<br/>(RenderParams, TtsParams, etc.)
    participant Socket as Unix Socket
    participant Daemon as sidequest-daemon<br/>(Python media services)

    Game->>Client: render(RenderParams { prompt, style, ... })
    Client->>Types: build_request_json("render", &params)
    Types-->>Client: JSON envelope { method, params }
    Client->>Socket: write_all(json_bytes)
    Socket->>Daemon: HTTP request
    Daemon-->>Socket: JSON response
    Socket-->>Client: read response bytes
    Client->>Types: deserialize → DaemonResponse<RenderResult>
    Types-->>Client: RenderResult { image_path, ... }
    Client-->>Game: Ok(RenderResult)

